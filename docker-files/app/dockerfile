
FROM maven:3.8.6-openjdk-8-slim AS build

WORKDIR /app

# Copy only the pom.xml first so Maven can cache dependencies
# in a separate layer (dependencies rarely change vs source code)
COPY pom.xml .
RUN mvn -B -q dependency:go-offline

# Now copy the actual source code and build the WAR
COPY src ./src
RUN mvn -B -q clean package -DskipTests

################################3

FROM tomcat:9.0-jdk8-temurin AS runtime

LABEL maintainer="vprofile" \
      description="VProfile webapp running on Tomcat (Elasticsearch removed)"

# Remove default Tomcat webapps (docs, examples, manager, host-manager, ROOT)
# so only our application is served - smaller image, smaller attack surface
RUN rm -rf /usr/local/tomcat/webapps/*

# curl is needed for the HEALTHCHECK below (not present in the base image)
RUN apt-get update \
    && apt-get install -y --no-install-recommends curl \
    && rm -rf /var/lib/apt/lists/*

# Copy the WAR built in stage 1 and deploy it as ROOT so the app
# is served at http://<host>:8080/ instead of /vprofile-v2
COPY --from=build /app/target/*.war /usr/local/tomcat/webapps/ROOT.war

# Run as a non-root user (Docker/Tomcat best practice)
RUN groupadd -r tomcat && useradd -r -g tomcat -d /usr/local/tomcat tomcat \
    && chown -R tomcat:tomcat /usr/local/tomcat
USER tomcat

EXPOSE 8080

HEALTHCHECK --interval=30s --timeout=5s --start-period=40s --retries=3 \
    CMD curl -f http://localhost:8080/ || exit 1

CMD ["catalina.sh", "run"]